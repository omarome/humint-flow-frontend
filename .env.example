# ─────────────────────────────────────────────────────────────
# Environment variables — copy to .env.development or .env.production
# All variables prefixed with VITE_ are exposed to the client.
# ─────────────────────────────────────────────────────────────

# Backend API base URL
#   Dev:  http://localhost:8080/api
#   Prod: /api  (NGINX reverse-proxies to the backend)
VITE_API_BASE_URL=http://localhost:8080/api

# App title (shown in the UI header)
VITE_APP_TITLE=Smart Filter Hub

# Auto-dismiss duration for the data-source banner (ms)
VITE_BANNER_DURATION=5000
